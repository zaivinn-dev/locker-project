LOCKER_DEVICE_MODE=esp32

# Primary ESP32 URL - Change 192.168.100.19 to your ESP32's actual IP address
# Find the IP by:
#   - Checking your router's connected devices
#   - Looking at the ESP32's serial monitor output
#   - Using network scanner tools
ESP32_BASE_URL=http://192.168.2.104

# Fallback URLs (comma-separated) - tried if primary URL fails
# Common IPs to try: 192.168.100.18, 192.168.4.1, 192.168.1.100
ESP32_FALLBACK_URLS=http://192.168.2.105,http://192.168.2.106

# Connection timeout (seconds) - how long to wait for ESP32 to accept connection
# Increase if ESP32 is slow to respond (e.g., 10 seconds)
ESP32_CONNECT_TIMEOUT=5.0

# Read timeout (seconds) - how long to wait for ESP32 to send response
# Increase if ESP32 API responses are slow (e.g., 10 seconds)
ESP32_TIMEOUT=5.0

# Maximum HTTP retry attempts for failed requests (default: 1)
# Increase if network is unstable (e.g., 3 retries)
ESP32_MAX_RETRIES=1